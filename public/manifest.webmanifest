{
  "id": "/iron-log/",
  "name": "Raise That Bar",
  "short_name": "RTB",
  "description": "Strength training tracker — raise that bar.",
  "lang": "en",
  "dir": "ltr",
  "start_url": "/iron-log/",
  "scope": "/iron-log/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#0C0B0A",
