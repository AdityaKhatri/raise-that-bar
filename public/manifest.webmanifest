  "orientation": "portrait",
  "categories": ["fitness", "health", "sports"],
  "icons": [
    { "src": "/iron-log/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/iron-log/icons/icon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/iron-log/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/iron-log/icons/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "/iron-log/icons/apple-touch-icon.png", "sizes": "180x180", "type": "image/png", "purpose": "any" }
  ],
  "shortcuts": [
    {
      "name": "Today's Workout",
      "short_name": "Today",
      "description": "Go to today's workout",
      "url": "/iron-log/",
      "icons": [{ "src": "/iron-log/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Exercise Library",
      "short_name": "Library",
      "description": "Browse the exercise library",
      "url": "/iron-log/#exercises",
      "icons": [{ "src": "/iron-log/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "screenshots": [
